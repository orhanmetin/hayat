# Public site URL (no trailing slash). Used for CORS and Strava OAuth redirects.
PUBLIC_URL=http://167.233.16.12

# Host port for the web container (nginx)
HTTP_PORT=80

# Generate: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret

# Strava (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Optional: Neon PostgreSQL (requires Npgsql migration support — not enabled by default)
# ConnectionStrings__DefaultConnection=Host=ep-xxx-pooler.region.aws.neon.tech;Database=hayat;Username=...;Password=...;SSL Mode=Require
